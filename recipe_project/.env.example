# =============================================================================
# Environment Variables Template for Production
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# 
# For Heroku deployment, set these using:
#   heroku config:set VARIABLE_NAME="value"
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------

# REQUIRED: Generate a new secret key for production
# Generate using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-super-secret-key-here-minimum-50-characters-long-random-string

# REQUIRED: Django settings module (use prod for production)
DJANGO_SETTINGS_MODULE=config.settings.prod

# REQUIRED: Allowed hosts (comma-separated, no spaces)
# Development: localhost,127.0.0.1
# Production: your-domain.com,www.your-domain.com,your-app.herokuapp.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Security Settings (Enable these for production with HTTPS)
# -----------------------------------------------------------------------------

# Set to "true" only after SSL/HTTPS is configured
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false

# CSRF Trusted Origins (comma-separated, include protocol)
# Example: https://your-domain.com,https://www.your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# Heroku automatically provides DATABASE_URL when you add PostgreSQL addon
# For local development, you can use SQLite (default) or set a PostgreSQL URL:
# DATABASE_URL=postgres://username:password@localhost:5432/dbname
DATABASE_URL=

# -----------------------------------------------------------------------------
# AWS S3 Configuration (for media files)
# -----------------------------------------------------------------------------

# Set to "true" to use S3 for media file storage (recommended for production)
USE_S3=false

# AWS Credentials (get these from AWS IAM)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 Bucket Configuration
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# -----------------------------------------------------------------------------
# Optional Settings
# -----------------------------------------------------------------------------

# Email Configuration (if sending emails)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Sentry for Error Monitoring (recommended for production)
# SENTRY_DSN=https://your-sentry-dsn

# Redis Cache (if using caching)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Production Deployment Quick Reference
# =============================================================================
#
# 1. Generate SECRET_KEY:
#    python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# 2. Set Heroku environment variables:
#    heroku config:set DJANGO_SECRET_KEY="your-secret-key"
#    heroku config:set DJANGO_ALLOWED_HOSTS="your-app.herokuapp.com"
#    heroku config:set DJANGO_SECURE_SSL_REDIRECT="true"
#    heroku config:set DJANGO_SESSION_COOKIE_SECURE="true"
#    heroku config:set DJANGO_CSRF_COOKIE_SECURE="true"
#    heroku config:set DJANGO_CSRF_TRUSTED_ORIGINS="https://your-app.herokuapp.com"
#
# 3. AWS S3 (if using):
#    heroku config:set USE_S3="true"
#    heroku config:set AWS_ACCESS_KEY_ID="your-key"
#    heroku config:set AWS_SECRET_ACCESS_KEY="your-secret"
#    heroku config:set AWS_STORAGE_BUCKET_NAME="your-bucket"
#    heroku config:set AWS_S3_REGION_NAME="your-region"
#
# 4. View all config:
#    heroku config
#
# =============================================================================
